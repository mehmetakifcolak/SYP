{
  "Data": {
    "Default": {
      "ConnectionString": "Data Source=App_Data/databases/SYP_Default_v1.db",
      "ProviderName": "Microsoft.Data.Sqlite"
    },
  },
  "ClamAV": {
    "Enabled": false
  },
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Serenity.Web.NodeScriptRunner": "None"
    }
  },
  "StartNodeScripts": "tsbuild:watch"
}
